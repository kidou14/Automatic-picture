# Anthropic Claude (for page analysis + Seedance prompt generation)
ANTHROPIC_API_KEY=sk-ant-...

# OpenRouter (for Seedance video generation)
# Get token at: https://openrouter.ai/settings/keys
OPENROUTER_API_KEY=sk-or-v1-...

# Optional: override Seedance model ID (default: bytedance/seedance-2.0)
# SEEDANCE_MODEL=bytedance/seedance-2.0

# Server port (default: 4321)
# PORT=4321
