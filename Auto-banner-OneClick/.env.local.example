# Copy this file to .env.local and fill in your API key
# Anthropic Claude API key (required for AI copy generation and Claude SVG logo)
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI API key (required for DALL-E logo generation)
OPENAI_API_KEY=sk-...

# Optional: Override the Claude model
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Optional: Server port (default: 4318)
# PORT=4318

# Optional: Page load wait time in ms (default: 1200)
# CAPTURE_WAIT_MS=1200

# Optional: Export output directory (default: ~/Downloads/appstore-auto-screenshots-oneclick)
# EXPORT_OUTPUT_DIR=/path/to/your/exports
